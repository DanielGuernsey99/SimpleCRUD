@model SimpleCRUD.UI.ViewModels.TableViewModel

<link rel="stylesheet" href="~/Scripts/Pages/User.css" asp-append-version="true" />

<div class="card shadow-sm border-0 users-card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title h5">@Model.Title</h3>
        <a asp-controller="User" asp-action="Create" id="btnAddUser" class="btn btn-light">
            Add User
        </a>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 users-table">
                <thead>
                    <tr>
                        @foreach (var header in Model.Headers)
                        {
                            <th>@header</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows != null && Model.Rows.Any())
                    {
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                @foreach (var cell in row)
                                {
                                    <td>@cell</td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="@Model.Headers.Count" class="empty-state">
                                No data available.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>