@model SimpleCRUD.UI.Models.User.CreateUserViewModel

@section Styles {
    <link rel="stylesheet" href="~/Scripts/Pages/User.css" asp-append-version="true" />
}

<div class="card shadow-sm border-0 users-card mb-4">
    <div class="card-header">
        <h3 class="card-title h5 mb-0">Add User</h3>
    </div>

    <div class="card-body p-4">
        <form asp-controller="User" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="FirstName" class="form-label"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LastName" class="form-label"></label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save User</button>
                <a asp-controller="User" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}